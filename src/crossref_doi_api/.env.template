# Crossref API Configuration
# Copy this file to .env and fill in your actual credentials

# Your Crossref member ID (number)
CROSSREF_MEMBER_ID=your_member_id

# Your Crossref login credentials
CROSSREF_USERNAME=your_username_or_email
CROSSREF_PASSWORD=your_password

# Bibliography ODS file path for metadata enrichment
# This ODS file should contain the full bibliography with bibkey as unique identifier
BIBLIOGRAPHY_ODS_PATH=/path/to/your/bibliography.ods

# Authors CSV file path for clean author name lookup
# This CSV should have columns: login, firstname, lastname (in clean Unicode)
AUTHORS_CSV_PATH=/path/to/your/authors.csv

# Bibkey column name in your CSV files (default: _article_bib_key)
# Set this if your CSV uses a different column name for bibkeys
BIBKEY_COLUMN_NAME=_article_bib_key